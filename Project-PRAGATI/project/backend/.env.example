GEE_PROJECT=your-gee-project-id

# Database — defaults to SQLite if not set (no setup needed for demo)
# DATABASE_URL=postgresql://postgres:password@localhost:5432/pragati

# JWT Secret Key for session authentication (required for production)
SECRET_KEY=your-jwt-secret-key-change-in-production

# Service Account for GEE (optional - leave blank to use personal earthengine auth)
GEE_SERVICE_ACCOUNT=your-service-account@project.iam.gserviceaccount.com
GEE_KEY_FILE=./gee-key.json

# Gemini API Key for AI chatbot (optional - falls back to rule-based engine)
GEMINI_API_KEY=your_gemini_api_key_here

# Redis URL for distributed caching (optional - falls back to SQLite cache)
# REDIS_URL=redis://localhost:6379

# Frontend URL for CORS
FRONTEND_URL=http://localhost:5173
